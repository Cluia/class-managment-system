# Flask
FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=change-me-in-production

# Database (local: SQLite; no Docker o Compose sobrescreve para Postgres)
DATABASE_URL=sqlite:///smart_class_plan.db

# Segurança
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
MAX_CONTENT_LENGTH=1048576
RATELIMIT_ENABLED=true
RATELIMIT_DEFAULT=120 per minute
RATELIMIT_AI=10 per minute

# Groq (chave em https://console.groq.com/keys — nunca commitar)
GROQ_API_KEY=
# Modelos sugeridos: llama-3.1-8b-instant (rápido) | llama-3.3-70b-versatile (melhor qualidade)
GROQ_MODEL=llama-3.1-8b-instant
GROQ_API_BASE=https://api.groq.com/openai/v1

# Se a API falhar (429, timeout), usa sugestões mock em desenvolvimento
AI_FALLBACK_TO_MOCK=true
